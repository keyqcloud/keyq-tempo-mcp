#!/bin/sh
# tempo-sprint-mode pre-push guard
#
# Refuses pushes FROM a `tempo/*` branch TO the configured target_branch
# (.claude/sprint-config.json). This catches the failure mode where the
# sprint runner — which works on `tempo/card-N-...` branches — would
# bypass PR review by pushing its work directly to main / dev / etc.
#
# Humans pushing to target_branch from any non-tempo branch are allowed.
# This is the normal flow (release commit on main, hotfix from another
# branch, initial setup, etc.) and the hook stays out of the way for it.
#
# Force-pushes to a tempo/* feature branch (rebases on your own work) are
# also fine and unaffected.
#
# Bypass for a one-off:  SKIP_TEMPO_HOOK=1 git push

# Allow explicit bypass.
if [ -n "$SKIP_TEMPO_HOOK" ]; then
  exit 0
fi

CONFIG=".claude/sprint-config.json"

# If sprint-config.json isn't present, this isn't a sprint-mode repo —
# don't enforce anything.
if [ ! -f "$CONFIG" ]; then
  exit 0
fi

# Read target_branch via jq if available, otherwise crude grep fallback.
TARGET_BRANCH=""
if command -v jq >/dev/null 2>&1; then
  TARGET_BRANCH=$(jq -r '.target_branch // "main"' "$CONFIG" 2>/dev/null)
else
  TARGET_BRANCH=$(grep -o '"target_branch"[^,}]*' "$CONFIG" | sed 's/.*"\([^"]*\)"$/\1/')
fi
[ -z "$TARGET_BRANCH" ] && TARGET_BRANCH="main"

# git pre-push hook stdin: <local-ref> <local-sha> <remote-ref> <remote-sha>
# (one line per ref being pushed).
while read local_ref local_sha remote_ref remote_sha; do
  remote_branch="${remote_ref#refs/heads/}"
  local_branch="${local_ref#refs/heads/}"

  # Only refuse if the SOURCE branch is tempo/* AND the destination is
  # the protected target_branch. This is the runner-bypass-PR scenario.
  # Anything else (human → main, runner → its own feature branch,
  # human force-push their own branch) is allowed.
  if [ "$remote_branch" = "$TARGET_BRANCH" ]; then
    case "$local_branch" in
      tempo/*)
        echo "🛑 tempo-sprint-mode: refused push from '$local_branch' to '$TARGET_BRANCH'."
        echo "   Sprint runner branches must go through PR review."
        echo "   Open a PR with:  gh pr create --base $TARGET_BRANCH"
        echo "   Bypass for a one-off:  SKIP_TEMPO_HOOK=1 git push"
        exit 1
        ;;
    esac
  fi
done

exit 0
